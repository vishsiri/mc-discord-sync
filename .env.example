# Discord Bot
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here

# Discord Sync Settings
DISCORD_SYNCED_ROLE_ID=role_id_to_add_on_sync
DISCORD_REMOVE_ROLE_ID=role_id_to_remove_on_sync
ENABLE_NICKNAME_SYNC=false
NICKNAME_FORMAT=[minedream] {ign}

# Database (MariaDB)
DATABASE_URL=mysql://user:password@localhost:3306/mc_discord_sync

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CHANNEL=minedream:sync:success

# API Security
API_SECRET_KEY=your_secret_key_here

# App
PORT=3000
