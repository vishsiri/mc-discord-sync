# Discord Bot
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here

# Discord Sync Settings
DISCORD_SYNCED_ROLE_ID=role_id_to_add_on_sync
DISCORD_REMOVE_ROLE_ID=role_id_to_remove_on_sync
ENABLE_ROLE_SYNC=true
ENABLE_NICKNAME_SYNC=false
NICKNAME_FORMAT=[minedream] {ign}
SYNC_ROLE_MAPPINGS_FILE=rolemaps.yml
# SYNC_ROLE_MAPPINGS=[{"key":"vip","weight":10,"minecraftGroup":"vip","discordRoleId":"123456789012345678"},{"key":"diamond","weight":20,"minecraftGroup":"diamond","discordRoleId":"223456789012345678"},{"key":"platinum","weight":30,"minecraftGroup":"platinum","discordRoleId":"323456789012345678"}]

# Database (MariaDB)
DATABASE_URL=mysql://user:password@localhost:3306/mc_discord_sync

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Legacy alias still supported:
REDIS_CHANNEL=minedream:sync:success
# Preferred explicit channel names:
REDIS_SYNC_SUCCESS_CHANNEL=minedream:sync:success
REDIS_UNSYNC_CHANNEL=minedream:sync:success
REDIS_BOOST_CHANNEL=minedream:sync:boost
REDIS_RANK_SYNC_CHANNEL=minedream:sync:rank

# API Security
API_SECRET_KEY=your_secret_key_here

# App
PORT=3000
